# PodForge Configuration
# Copy this file to .env and fill in your values.

# ── Backend ──────────────────────────────────────────────────

# TTS Server URL (Colab ngrok URL or local server)
PODFORGE_TTS_URL=http://localhost:8809

# Backend server
PODFORGE_HOST=0.0.0.0
PODFORGE_PORT=8080

# ── Frontend (frontend/.env.local) ───────────────────────────

# Backend URL for API proxy (used by next.config.ts rewrites)
# BACKEND_URL=http://localhost:8080

# Direct API URL (bypasses Next.js proxy, set if backend is remote)
# NEXT_PUBLIC_API_URL=http://localhost:8080

# WebSocket URL for streaming generation
# NEXT_PUBLIC_WS_URL=ws://localhost:8080
